<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="hrmis_new_transfer_request" name="HRMIS: New Transfer Request">
        <t t-set="error" t-value="request.params.get('error')"/>
        <t t-set="success" t-value="request.params.get('success')"/>
        <t t-if="error">
            <div class="hrmis-alert hrmis-alert--error"><t t-esc="error"/></div>
        </t>
        <t t-if="success">
            <div class="hrmis-alert hrmis-alert--success"><t t-esc="success"/></div>
        </t>

        <t t-if="tab == 'new'">
            <t t-set="employee" t-value="request.env.user.employee_ids[:1]"/>
            <form class="hrmis-form hrmis-transfer-request-form"
                  t-att-data-employee-bps="employee.hrmis_bps"
                  t-att-action="'/hrmis/staff/%s/transfer/submit' % employee.id"
                  t-att-data-employee-id="employee.id"
                  t-att-data-current-district-name="(employee and employee.district_id and employee.district_id.name) or ''"
                  t-att-data-current-facility-name="(employee and employee.facility_id and employee.facility_id.name) or ''"
                  t-att-data-current-designation-name="(employee and employee.hrmis_designation and employee.hrmis_designation.name) or ''"
                  data-transfer-locations-url="/hrmis/api/transfer/emr_locations"
                  method="post"
                  enctype="multipart/form-data">

                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <input type="hidden" name="redirect_base" value="/hrmis/transfer"/>
                <input type="hidden" name="current_emr_district_id" value=""/>
                <input type="hidden" name="current_emr_facility_id" value=""/>
                <input type="hidden" name="required_emr_district_id" value=""/>
                <input type="hidden" name="required_emr_facility_id" value=""/>

                <div class="hrmis-form__grid">

                    <div class="hrmis-field hrmis-field--wide">
                        <label>Current Posting</label>
                    </div>

                    <div class="hrmis-field">
                        <label>Current District<span class="req">*</span></label>
                        <select class="hrmis-input js-hrmis-current-district"
                                disabled="disabled"
                                required="required">
                            <option value="">Select district</option>
                        </select>
                    </div>

                    <div class="hrmis-field">
                        <label>Current Facility<span class="req">*</span></label>
                        <select class="hrmis-input js-hrmis-current-facility"
                                disabled="disabled"
                                required="required">
                            <option value="">Select facility</option>
                        </select>
                    </div>

                    <div class="hrmis-field hrmis-field--wide">
                        <label>Current Designation<span class="req">*</span></label>
                        <input class="hrmis-input hrmis-input--wide"
                               type="text"
                               t-att-value="(employee and employee.hrmis_designation and employee.hrmis_designation.name) or ''"
                               readonly="readonly"
                               required="required"/>
                    </div>

                    <div class="hrmis-field hrmis-field--wide">
                        <label>Required Posting</label>
                    </div>

                    <div class="hrmis-field">
                        <label>Required District<span class="req">*</span></label>
                        <select class="hrmis-input js-hrmis-required-district"
                                required="required">
                            <option value="">Select district</option>
                        </select>
                        <div class="hrmis-help js-hrmis-transfer-eligibility-msg"
                             style="margin-top:6px; color:#a00; font-weight:700; display:none;">
                            <!-- filled by JS -->
                        </div>
                    </div>

                    <div class="hrmis-field">
                        <label>Required Facility<span class="req">*</span></label>
                        <select class="hrmis-input js-hrmis-required-facility"
                                required="required">
                            <option value="">Select facility</option>
                        </select>
                        <div class="hrmis-help js-hrmis-transfer-vacancy"
                             style="margin-top:6px; color:#111; font-weight:700; display:none;">
                            <!-- filled by JS -->
                        </div>
                    </div>

                    <div class="hrmis-field">
                        <label>Required Designation<span class="req">*</span></label>
                        <select class="hrmis-input js-hrmis-required-designation"
                                name="requested_designation"
                                required="required">
                            <option value="">Select required designation</option>
                            <option value="medical_officer">Medical Officer</option>
                            <option value="women_medical_officer">Women Medical Officer</option>
                            <option value="specialist">Specialist</option>
                            <option value="administrator">Administrator</option>
                        </select>
                    </div>

                    <div class="hrmis-field hrmis-field--wide">
                        <label>Justification<span class="req">*</span></label>
                        <textarea class="hrmis-input hrmis-input--wide"
                                  name="justification"
                                  rows="4"
                                  required="required"></textarea>
                    </div>

                    <div class="hrmis-field hrmis-field--wide js-hrmis-support-doc">
                        <label>Supporting document</label>
                        <div class="hrmis-help js-hrmis-support-doc-note">Optional.</div>
                        <input class="hrmis-input js-hrmis-support-doc-file"
                               type="file"
                               name="support_document"
                               accept=".pdf,.png,.jpg,.jpeg,.doc,.docx"/>
                    </div>

                </div>

                <div class="hrmis-form__actions">
                    <button
                        class="hrmis-btn hrmis-btn--primary hrmis-btn--lg hrmis-btn--sameheight"
                        type="submit">
                        Submit
                    </button>
                </div>
            </form>
        </t>
    </template>
</odoo>