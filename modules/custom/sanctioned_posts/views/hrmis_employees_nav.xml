<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="hrmis_nav_add_employees" inherit_id="hr_holidays_updates.hrmis_ui_layout">
        <xpath expr="//nav[contains(@class,'hrmis-nav')]//a[contains(normalize-space(.),'Promotion Requests')]"
               position="after">
        
            <t t-if="request.env.user.has_group('base.group_system')">
                <a t-att-class="'hrmis-nav__item' + (' is-active' if active_menu == 'employees' else '')"
                   t-att-href="'/hrmis/employees'">
                    <span class="hrmis-nav__icon" aria-hidden="true">
                        <i class="fa fa-users" aria-hidden="true"/>
                    </span>
                    <span class="hrmis-nav__label">Employees</span>
                </a>
            </t>

        </xpath>
    </template>
</odoo>