<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <template id="hrmis_sanctioned_posts_upload_page" name="HRMIS Sanctioned Posts Upload">
        <t t-call="hr_holidays_updates.hrmis_ui_layout">

            <div class="hrmis-panel">
                <div class="hrmis-panel__header">
                    <div class="hrmis-panel__title">Sanctioned Posts - XLSX Upload</div>
                </div>

                <div class="hrmis-panel__body">

                    <t t-if="not request.env.user.has_group('base.group_system')">
                        <div class="alert alert-danger mb-0">
                            You are not allowed to access this page.
                        </div>
                    </t>

                    <t t-else="">

                        <!-- Flash Messages -->
                        <t t-if="flash_success">
                            <div class="alert alert-success mb-3">
                                <t t-esc="flash_success"/>
                            </div>
                        </t>

                        <t t-if="flash_error">
                            <div class="alert alert-danger mb-3">
                                <t t-esc="flash_error"/>
                            </div>
                        </t>

                        <!-- Main Upload -->
                        <div class="d-flex justify-content-center my-4">
                            <form action="/hrmis/sanctioned_posts/upload_xlsx"
                                  method="post"
                                  enctype="multipart/form-data"
                                  class="text-center">

                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                <input id="xlsx_file"
                                       type="file"
                                       name="xlsx_file"
                                       accept=".xlsx"
                                       class="d-none"
                                       onchange="this.form.submit()"/>

                                <label for="xlsx_file" class="btn btn-success">
                                    Upload XLSX
                                </label>

                                <div class="text-muted mt-2" style="font-size: 0.9rem;">
                                    Select an .xlsx file to upload; preview will appear below.
                                </div>
                            </form>
                        </div>

                        <!-- Master Data Uploads -->
                        <div class="card p-3 my-4" style="border:1px solid #eee; border-radius:10px;">
                            <div style="font-size:16px; font-weight:700;">Master Data Uploads</div>
                            <div class="text-muted mt-1" style="font-size:0.9rem;">
                                Upload facilities and designations files from here.
                            </div>

                            <div class="d-flex justify-content-center gap-4 flex-wrap mt-3">

                                <!-- Facilities Upload -->
                                <form action="/hrmis/sanctioned_posts/upload_facilities"
                                      method="post"
                                      enctype="multipart/form-data"
                                      class="text-center m-0">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                    <input id="facilities_xlsx_file"
                                           type="file"
                                           name="facilities_xlsx_file"
                                           accept=".xlsx"
                                           class="d-none"
                                           onchange="this.form.submit()"/>

                                    <label for="facilities_xlsx_file" class="btn btn-outline-primary">
                                        Upload Facilities XLSX
                                    </label>

                                    <div class="text-muted mt-2" style="font-size:12px;">
                                        Facility upload placeholder.
                                    </div>
                                </form>

                                <!-- Designations Upload with sheet selection -->
                                <form action="/hrmis/sanctioned_posts/upload_designations"
                                      method="post"
                                      enctype="multipart/form-data"
                                      class="text-center m-0 hrmis-xlsx-upload-form">

                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="sheet_name" class="js-sheet-name" value=""/>

                                    <input id="designations_xlsx_file"
                                           type="file"
                                           name="designations_xlsx_file"
                                           accept=".xlsx"
                                           class="d-none js-xlsx-file"/>

                                    <label for="designations_xlsx_file" class="btn btn-outline-secondary">
                                        Upload Designations XLSX
                                    </label>

                                    <div class="mt-2">
                                        <select class="form-select js-sheet-select"
                                                style="min-width:220px; display:none;"
                                                disabled="disabled">
                                            <option value="" selected="selected" disabled="disabled">Select sheet…</option>
                                        </select>
                                    </div>

                                    <div class="mt-2 js-sheet-hint text-muted"
                                         style="font-size:12px; display:none;">
                                        Select the sheet that contains designation data.
                                    </div>

                                    <div class="mt-2">
                                        <button type="submit" class="btn btn-sm btn-dark">
                                            Process Designations
                                        </button>
                                    </div>
                                </form>

                            </div>
                        </div>

                        <!-- Error -->
                        <t t-if="upload_error">
                            <div class="alert alert-danger">
                                <t t-esc="upload_error"/>
                            </div>
                        </t>

                        <!-- Preview / Results -->
                        <t t-if="upload_result">
                            <div class="alert alert-info">
                                <div><strong>Total Records:</strong> <t t-esc="upload_result.get('count', 0)"/></div>
                                <div class="mt-1">
                                    <strong>Columns:</strong>
                                    <t t-esc="', '.join(upload_result.get('columns', []))"/>
                                </div>
                            </div>

                            <t t-if="attachment_id">
                                <div class="d-flex justify-content-center gap-2 my-3 flex-wrap">

                                    <a class="btn btn-outline-success"
                                       t-att-href="'/hrmis/sanctioned_posts/download_xlsx?attachment_id=%s' % attachment_id">
                                        Download Uploaded XLSX
                                    </a>

                                    <form action="/hrmis/sanctioned_posts/create_users" method="post" class="text-center m-0">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <input type="hidden" name="attachment_id" t-att-value="attachment_id"/>
                                        <button type="submit" class="btn btn-primary">
                                            Create Users (Import All)
                                        </button>
                                    </form>

                                </div>

                                <div class="text-muted text-center mt-2" style="font-size: 0.9rem;">
                                    This will create users for all rows (skips duplicates by CNIC/login). You can also download the uploaded XLSX.
                                </div>
                            </t>

                            <t t-if="upload_result.get('created') is not None">
                                <div class="alert alert-success">
                                    <div><strong>Created:</strong> <t t-esc="upload_result.get('created')"/></div>
                                    <div><strong>Skipped (duplicates/invalid):</strong> <t t-esc="upload_result.get('skipped')"/></div>
                                </div>

                                <t t-if="upload_result.get('errors')">
                                    <div class="alert alert-warning">
                                        <strong>Sample Errors (max 50):</strong>
                                        <ul class="mb-0">
                                            <t t-foreach="upload_result.get('errors')" t-as="err">
                                                <li><t t-esc="err"/></li>
                                            </t>
                                        </ul>
                                    </div>
                                </t>
                            </t>

                            <t t-if="creds_attachment_id">
                                <div class="alert alert-secondary d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>Credentials file ready.</strong>
                                        Download CSV of created logins + passwords.
                                    </div>
                                    <a class="btn btn-outline-dark btn-sm"
                                       t-att-href="'/web/content/%s?download=true' % creds_attachment_id">
                                        Download credentials CSV
                                    </a>
                                </div>
                            </t>

                            <t t-if="failed_attachment_id">
                                <div class="alert alert-warning mt-2">
                                    Some records were skipped. You can download the skipped list with reasons:
                                    <a t-att-href="'/hrmis/sanctioned_posts/download_failed?attachment_id=%s' % failed_attachment_id"
                                       class="btn btn-sm btn-outline-danger ms-2">
                                        Download Skipped Records (XLSX)
                                    </a>
                                </div>
                            </t>

                            <t t-if="creds_preview">
                                <div class="table-responsive">
                                    <table class="table table-sm table-bordered align-middle">
                                        <thead>
                                            <tr>
                                                <th>Login (CNIC)</th>
                                                <th>Password</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="creds_preview" t-as="c">
                                                <tr>
                                                    <td><t t-esc="c.get('login')"/></td>
                                                    <td><t t-esc="c.get('password')"/></td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                    <div class="text-muted" style="font-size:0.9rem;">
                                        Showing first 50 created credentials. Download CSV for full list.
                                    </div>
                                </div>
                            </t>

                            <t t-if="request.env.user.has_group('base.group_system')">
                                <div class="d-flex justify-content-center my-3">
                                    <a class="btn btn-outline-primary"
                                       t-att-href="'/hrmis/staff/download_details?ids=all'">
                                        Download Staff Details
                                    </a>
                                </div>
                            </t>

                            <t t-if="upload_result.get('top10')">
                                <div class="table-responsive">
                                    <table class="table table-sm table-bordered align-middle">
                                        <thead>
                                            <tr>
                                                <t t-foreach="upload_result.get('columns', [])" t-as="col">
                                                    <th><t t-esc="col"/></th>
                                                </t>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="upload_result.get('top10')" t-as="row">
                                                <tr>
                                                    <t t-foreach="upload_result.get('columns', [])" t-as="col">
                                                        <td><t t-esc="row.get(col, '')"/></td>
                                                    </t>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </t>

                        </t>

                    </t>
                </div>
            </div>

        </t>
    </template>

</odoo>