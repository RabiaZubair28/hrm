<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <template id="hrmis_user_queue_page" name="HRMIS User Queue Monitor">
    <t t-call="hr_holidays_updates.hrmis_ui_layout">
      <t t-set="active_menu" t-value="'user_config'"/>

      <div class="container mt-4 mb-5">
        <div class="card p-3" style="border:1px solid #eee; border-radius:10px;">

          <div style="display:flex; justify-content:space-between; align-items:center; gap:12px;">
          <a t-if="latest_job"
            t-att-href="'/hrmis/user_config/recover/%s' % latest_job.id"
            class="btn btn-danger">
            Recover / Fix Job
          </a>
            <div>
              <div style="font-size:18px; font-weight:700;">User Sync Monitor</div>
              <div style="font-size:13px; color:#666;">
                Cron processes records in committed batches. Click refresh to update.
              </div>
            </div>
            <a href="/hrmis/user_config/queue" class="btn btn-secondary">Refresh</a>
          </div>

          <t t-if="not latest_job">
            <div class="alert alert-warning mt-3" role="alert">
              No import job found yet. Upload an XLSX first.
            </div>
          </t>

          <t t-if="latest_job">
            <div class="mt-3" style="font-size:13px; color:#444;">
              <div>
                <strong>Job ID:</strong> <t t-esc="latest_job.id"/>
                &#160; | &#160;
                <strong>Status:</strong> <t t-esc="latest_job.state"/>
                &#160; | &#160;
                <strong>Queued:</strong> <t t-esc="latest_job.queued_count"/>
              </div>
              <div>
                <strong>Processed:</strong> <t t-esc="latest_job.processed_count"/>
                &#160; | &#160;
                <strong>Created:</strong> <t t-esc="latest_job.created_count"/>
                &#160; | &#160;
                <strong>Failed:</strong> <t t-esc="latest_job.failed_count"/>
              </div>
            </div>

            <t t-if="latest_job.report_attachment_id">
              <div class="mt-3">
                <a class="btn btn-success"
                   t-att-href="'/web/content/%s?download=1' % latest_job.report_attachment_id.id">
                  Download Skipped/Failed Report (XLSX)
                </a>
              </div>
            </t>

            <t t-if="latest_job.state == 'done' and not latest_job.report_attachment_id">
              <div class="alert alert-info mt-3" role="alert">
                Job completed, but report is not available.
                <t t-if="latest_job.last_error">
                  <div style="margin-top:6px;"><strong>Reason:</strong> <t t-esc="latest_job.last_error"/></div>
                </t>
              </div>
            </t>

            <div class="mt-3" style="display:flex; gap:20px; flex-wrap:wrap;">
              <div style="padding:10px 12px; border:1px solid #f0f0f0; border-radius:10px;">
                Pending (Redis): <b><t t-esc="pending"/></b>
              </div>
              <div style="padding:10px 12px; border:1px solid #f0f0f0; border-radius:10px;">
                Processing (Redis): <b><t t-esc="processing"/></b>
              </div>
              <div style="padding:10px 12px; border:1px solid #f0f0f0; border-radius:10px;">
                Done (Redis): <b><t t-esc="done"/></b>
              </div>
              <div style="padding:10px 12px; border:1px solid #f0f0f0; border-radius:10px;">
                Failed (Redis): <b><t t-esc="failed"/></b>
              </div>
            </div>

            <t t-set="total" t-value="(pending + processing + done + failed) or 0"/>
            <t t-set="pct" t-value="(100.0 * (done + failed) / total) if total else 0"/>
            <div class="mt-3">
              <div style="font-size:13px; color:#666;">
                Progress: <strong><t t-esc="('%.1f' % pct)"/></strong>%
              </div>
              <div style="height:10px; background:#eee; border-radius:999px; overflow:hidden;">
                <div t-att-style="'height:10px; width:' + ('%.1f' % pct) + '%; background:#22c55e; border-radius:999px;'"></div>
              </div>
            </div>

            <!-- Pending preview table -->
            <div class="mt-4">
              <div style="font-weight:700;">Pending (first 10)</div>
              <t t-if="not pending_list">
                <div style="font-size:13px; color:#666; margin-top:6px;">No pending items.</div>
              </t>
              <t t-if="pending_list">
                <table class="table table-sm mt-2" style="font-size:13px;">
                  <thead>
                    <tr>
                      <th>Pers.no.</th>
                      <th>Row</th>
                      <th>Name at birth</th>
                      <th>Username</th>
                      <th>Temp Password</th>
                    </tr>
                  </thead>
                  <tbody>
                    <t t-foreach="pending_list" t-as="it">
                      <tr>
                        <td><t t-esc="it.get('login','')"/></td>
                        <td><t t-esc="it.get('row','')"/></td>
                        <td><t t-esc="it.get('name','')"/></td>
                        <td><t t-esc="it.get('login','')"/></td>
                        <td><t t-esc="it.get('temp_password','') or it.get('password','')"/></td>
                      </tr>
                    </t>
                  </tbody>
                </table>
              </t>
            </div>

            <!-- Failed preview table -->
            <div class="mt-4">
              <div style="font-weight:700;">Failed (first 10)</div>
              <t t-if="not failed_list">
                <div style="font-size:13px; color:#666; margin-top:6px;">No failed items.</div>
              </t>
              <t t-if="failed_list">
                <table class="table table-sm mt-2" style="font-size:13px;">
                  <thead>
                    <tr>
                      <th>Pers.no.</th>
                      <th>Row</th>
                      <th>Name at birth</th>
                      <th>Reason</th>
                    </tr>
                  </thead>
                  <tbody>
                    <t t-foreach="failed_list" t-as="it">
                      <tr>
                        <td><t t-esc="it.get('login','')"/></td>
                        <td><t t-esc="it.get('row','')"/></td>
                        <td><t t-esc="it.get('name','')"/></td>
                        <td><t t-esc="it.get('error','')"/></td>
                      </tr>
                    </t>
                  </tbody>
                </table>
              </t>
            </div>

            <!-- Done preview table -->
            <div class="mt-4">
              <div style="font-weight:700;">Created (first 10)</div>
              <t t-if="not done_list">
                <div style="font-size:13px; color:#666; margin-top:6px;">No created items yet.</div>
              </t>
              <t t-if="done_list">
                <table class="table table-sm mt-2" style="font-size:13px;">
                  <thead>
                    <tr>
                      <th>Pers.no.</th>
                      <th>Row</th>
                      <th>Name at birth</th>
                      <th>Username</th>
                    </tr>
                  </thead>
                  <tbody>
                    <t t-foreach="done_list" t-as="it">
                      <tr>
                        <td><t t-esc="it.get('login','')"/></td>
                        <td><t t-esc="it.get('row','')"/></td>
                        <td><t t-esc="it.get('name','')"/></td>
                        <td><t t-esc="it.get('_login_final','') or it.get('login','')"/></td>
                      </tr>
                    </t>
                  </tbody>
                </table>
              </t>
            </div>

          </t>
        </div>
      </div>

    </t>
  </template>
</odoo>