<odoo>
  <data noupdate="1">
    <record id="ir_cron_hrmis_auto_forward_approvals" model="ir.cron">
      <field name="name">HRMIS Auto Forward Approvals</field>

      <!-- In some versions it's 'model_id', in others it's 'model_id' still.
           You already have model_hrmis_approval_status, so keep this -->
      <field name="model_id" ref="model_hrmis_approval_status"/>

      <field name="state">code</field>
      <field name="code">model.cron_auto_forward_approvals()</field>

      <field name="interval_number">1</field>
      <field name="interval_type">minutes</field>

      <field name="active">True</field>
    </record>
  </data>
</odoo>
