<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="hrmis_profile_approvals" name="HRMIS Profile Approvals">
        <t t-call="hr_holidays_updates.hrmis_ui_layout">
            <div class="hrmis-panel">

                <div class="hrmis-panel__header">
                    <div class="hrmis-panel__title">
                        Profile Update Requests
                    </div>
                </div>

                <div class="hrmis-panel__body">

                    <t t-if="not requests">
                        <div class="hrmis-empty">
                            No profile update requests pending.
                        </div>
                    </t>

                    <t t-if="requests">
                        <div class="hrmis-table hrmis-table--profile-approvals">
                            <div class="hrmis-table__head">
                                <div>Employee</div>
                                <div>Designation</div>
                                <div>Action</div>
                            </div>
                            <t t-foreach="requests" t-as="req">
                                <div class="hrmis-table__row">
                                    <div class="strong" data-label="Employee">
                                        <t t-esc="req.employee_id.name"/>
                                    </div>
                                    <div data-label="Designation">
                                        <t t-esc="req.hrmis_designation"/>
                                    </div>
                                    <div data-label="Action" class="hrmis-leave-row__actions">
                                        <a class="hrmis-btn hrmis-btn--outline"
                                           t-attf-href="/web#id={{ req.id }}&amp;model=hrmis.employee.profile.request&amp;view_type=form">
                                            Review
                                        </a>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>

</odoo>