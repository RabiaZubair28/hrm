<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="hrmis_profile_request_form" name="HRMIS Profile Update Request">
    <t t-call="hr_holidays_updates.hrmis_ui_layout">

      <div class="hrmis-panel">

        <!-- Header -->
        <div class="hrmis-panel__header">
          <div class="d-flex flex-column gap-1">
            <!-- <div>
              <a t-att-href="'/hrmis/staff/%s' % employee.id"
                 style="border-bottom:1px solid #2a2f31; color:#2a2f31; text-decoration:none;">
                &#8592; Back to Profile
              </a>
            </div> -->
            <div class="hrmis-panel__title">
              Welcome <t t-esc="(current_employee and current_employee.name) or (employee and employee.name) or ''"/>!
            </div>
            <div style="font-weight:600; opacity:0.85;">Please complete your profile first.</div>
          </div>
        </div>

        <!-- Body -->
        <div class="hrmis-panel__body">
          <t t-if="info">
            <div class="hrmis-alert hrmis-alert--success mt-2"><t t-esc="info"/></div>
          </t>
          <t t-if="error">
            <div class="hrmis-alert hrmis-alert--danger mt-2"><t t-esc="error"/></div>
          </t>
          <t t-if="success">
            <div class="hrmis-alert hrmis-alert--success mt-2"><t t-esc="success"/></div>
          </t>

          <t t-set="is_draft" t-value="req and (req.state == 'draft')"/>

          <form t-att-class="'hrmis-form mt-1 ' + ('' if is_draft else 'is-submitted')"
                id="profile_update_form"
                method="post"
                enctype="multipart/form-data"
                action="/hrmis/profile/request/submit"
                t-att-onsubmit="'return false;' if not is_draft else None">

            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
            <input type="hidden" name="request_id" t-att-value="req.id"/>

            <div class="hrmis-form__grid">

              <!-- ===================== Employee Information ===================== -->
              <div class="hrmis-section" style="grid-column: 1 / -1;">
                <div class="hrmis-panel">
                  <div class="hrmis-panel__title hrmis-panel__header" style="margin-bottom:10px;">
                    Employee Information
                  </div>

                  <div class="px-3 pt-1 pb-3">
                    <fieldset t-att-disabled="'disabled' if not is_draft else None" style="border:0; padding:0; margin:0;">
                      <div class="hrmis-form__grid">

                        <div class="hrmis-field">
                          <label>Personal Number</label>
                          <input class="hrmis-input" type="text" name="hrmis_employee_id"
                                 t-att-value="(req.hrmis_employee_id or current_employee.hrmis_employee_id or '') if is_draft else ''"
                                 t-att-readonly="'readonly' if not is_draft else None"/>
                        </div>

                        <div class="hrmis-field">
                          <label>CNIC<span class="req">*</span></label>
                          <input class="hrmis-input" type="text" name="hrmis_cnic"
                                 placeholder="12345-1234567-1"
                                 inputmode="numeric" autocomplete="off" maxlength="15"
                                 pattern="^\d{5}-\d{7}-\d$"
                                 title="CNIC format must be 12345-1234567-1"
                                 t-att-required="'required' if is_draft else None"
                                 t-att-value="(req.hrmis_cnic or current_employee.hrmis_cnic or '') if is_draft else ''"
                                 t-att-readonly="'readonly' if not is_draft else None"/>
                        </div>

                        <div class="hrmis-field">
                          <label>Father Name<span class="req">*</span></label>
                          <input class="hrmis-input" type="text" name="hrmis_father_name"
                                 t-att-required="'required' if is_draft else None"
                                 t-att-value="(req.hrmis_father_name or current_employee.hrmis_father_name or '') if is_draft else ''"
                                 t-att-readonly="'readonly' if not is_draft else None"/>
                        </div>

                        <div class="hrmis-field">
                          <label>Gender<span class="req">*</span></label>
                          <select class="hrmis-input" name="gender" t-att-required="'required' if is_draft else None"
                                  t-att-disabled="'disabled' if not is_draft else None">
                            <option value="" disabled="disabled" hidden="hidden"
                                    t-att-selected="(not is_draft) or (is_draft and not (req.gender or current_employee.gender))">
                              Select Gender
                            </option>
                            <option value="male" t-att-selected="is_draft and ((req.gender or current_employee.gender) == 'male')">Male</option>
                            <option value="female" t-att-selected="is_draft and ((req.gender or current_employee.gender) == 'female')">Female</option>
                            <option value="other" t-att-selected="is_draft and ((req.gender or current_employee.gender) == 'other')">Other</option>
                          </select>
                        </div>

                        <div class="hrmis-field">
                          <label>Date of Birth<span class="req">*</span></label>
                          <input class="hrmis-input" type="date" name="birthday"
                                 t-att-max="max_dob_str"
                                 t-att-required="'required' if is_draft else None"
                                 t-att-value="(req.birthday or current_employee.birthday or '') if is_draft else ''"
                                 t-att-readonly="'readonly' if not is_draft else None"/>
                        </div>

                        <div class="hrmis-field">
                          <label>Domicile<span class="req">*</span></label>
                          <select class="hrmis-input" name="hrmis_domicile" t-att-required="'required' if is_draft else None"
                                  t-att-disabled="'disabled' if not is_draft else None">
                            <option value="" disabled="disabled" hidden="hidden"
                                    t-att-selected="(not is_draft) or (is_draft and not (req.hrmis_domicile or current_employee.hrmis_domicile))">
                              Select Domicile
                            </option>
                            <t t-if="is_draft">
                              <t t-foreach="districts" t-as="d">
                                <option t-att-value="d.name"
                                        t-att-selected="(req.hrmis_domicile == d.name) or (current_employee.hrmis_domicile == d.name)">
                                  <t t-esc="d.name"/>
                                </option>
                              </t>
                            </t>
                          </select>
                        </div>

                        <div class="hrmis-field">
                          <label>Commission Year<span class="req">*</span></label>
                          <input class="hrmis-input" type="date" name="hrmis_commission_date"
                                 t-att-max="max_today_str"
                                 t-att-required="'required' if is_draft else None"
                                 t-att-value="(req.hrmis_commission_date or current_employee.hrmis_commission_date or '') if is_draft else ''"
                                 t-att-readonly="'readonly' if not is_draft else None"/>
                        </div>

                        <div class="hrmis-field">
                          <label>Merit Number<span class="req">*</span></label>
                          <input class="hrmis-input" type="text" name="hrmis_merit_number"
                                 t-att-required="'required' if is_draft else None"
                                 t-att-value="(req.hrmis_merit_number or current_employee.hrmis_merit_number or '') if is_draft else ''"
                                 t-att-readonly="'readonly' if not is_draft else None"/>
                        </div>

                        <div class="hrmis-field">
                          <label>Joining Date<span class="req">*</span></label>
                          <input class="hrmis-input" type="date" name="hrmis_joining_date"
                                 t-att-max="max_today_str"
                                 t-att-required="'required' if is_draft else None"
                                 t-att-value="(req.hrmis_joining_date or current_employee.hrmis_joining_date or '') if is_draft else ''"
                                 t-att-readonly="'readonly' if not is_draft else None"/>
                        </div>

                        <div class="hrmis-field">
                          <label>Cadre<span class="req">*</span></label>
                          <t t-set="current_cadre" t-value="req.hrmis_cadre or current_employee.hrmis_cadre"/>
                          <select class="hrmis-input js-cadre-select" name="hrmis_cadre" t-att-required="'required' if is_draft else None"
                                  t-att-disabled="'disabled' if not is_draft else None">
                            <option value="" disabled="disabled" hidden="hidden" t-att-selected="(not is_draft) or (is_draft and not current_cadre)">
                              Select Cadre
                            </option>
                            <t t-if="is_draft">
                              <t t-foreach="env['hrmis.cadre'].search([], order='name')" t-as="cadre">
                                <option t-att-value="cadre.id"
                                        t-att-selected="current_cadre and current_cadre.id == cadre.id">
                                  <t t-esc="cadre.name"/>
                                </option>
                              </t>
                            </t>
                          </select>
                        </div>

                        <div class="hrmis-field">
                          <label>Contact Number<span class="req">*</span></label>
                          <input class="hrmis-input" type="tel" name="hrmis_contact_info"
                                 inputmode="numeric" autocomplete="off" maxlength="11"
                                 placeholder="03XXXXXXXXX"
                                 pattern="^03\d{9}$"
                                 title="Contact must be 11 digits and start with 03"
                                 t-att-required="'required' if is_draft else None"
                                 t-att-value="(req.hrmis_contact_info or current_employee.hrmis_contact_info or '') if is_draft else ''"
                                 t-att-readonly="'readonly' if not is_draft else None"/>
                        </div>

                        <div class="hrmis-field">
                          <label>CNIC Front Scan<span class="req">*</span></label>
                          <t t-if="is_draft and req.hrmis_cnic_front">
                            <div style="font-size:12px;color:#666;margin-bottom:6px;">
                              Already uploaded: <t t-esc="req.hrmis_cnic_front_filename or 'CNIC Front'"/>
                            </div>
                          </t>
                          <t t-if="is_draft">
                            <input class="hrmis-input" type="file" name="hrmis_cnic_front"
                                   accept="image/*,.pdf"
                                   t-att-required="'required' if not req.hrmis_cnic_front else None"/>
                          </t>
                          <t t-if="not is_draft">
                            <input class="hrmis-input" type="text" readonly="readonly" value=""/>
                          </t>
                        </div>

                        <div class="hrmis-field">
                          <label>CNIC Back Scan<span class="req">*</span></label>
                          <t t-if="is_draft and req.hrmis_cnic_back">
                            <div style="font-size:12px;color:#666;margin-bottom:6px;">
                              Already uploaded: <t t-esc="req.hrmis_cnic_back_filename or 'CNIC Back'"/>
                            </div>
                          </t>
                          <t t-if="is_draft">
                            <input class="hrmis-input" type="file" name="hrmis_cnic_back"
                                   accept="image/*,.pdf"
                                   t-att-required="'required' if not req.hrmis_cnic_back else None"/>
                          </t>
                          <t t-if="not is_draft">
                            <input class="hrmis-input" type="text" readonly="readonly" value=""/>
                          </t>
                        </div>

                      </div>
                    </fieldset>
                  </div>
                </div>
              </div>

              <!-- ===================== Qualification History ===================== -->
              <div class="hrmis-section" style="grid-column: 1 / -1;">
                <div class="hrmis-panel">

                  <div class="hrmis-panel__title hrmis-panel__header" style="margin-bottom:10px;">
                    Qualification History
                  </div>

                  <div class="px-3 pt-1 pb-3">

                    <div class="d-flex align-items-center justify-content-between" style="gap:12px; margin-bottom:15px;">
                      <div style="color:#dc3545; font-weight:400; margin:0; padding:0; font-size: 16px">
                        Note: Kindly add your Qualification History carefully!
                      </div>

                      <t t-if="is_draft">
                        <button type="button"
                                class="hrmis-btn hrmis-btn--primary"
                                id="btn_add_qual_row">
                          Add
                        </button>
                      </t>
                    </div>

                    <fieldset t-att-disabled="'disabled' if not is_draft else None" style="border:0; padding:0; margin:0;">
                      <div id="qual_rows" class="d-flex flex-column gap-2"></div>
                    </fieldset>

                  <template id="tpl_qual_row">
                    <div class="hrmis-leave-row-wrap d-flex align-items-stretch" style="gap:10px; border: 2px solid black">

                      <div class="hrmis-repeat-row hrmis-card p-3"
                           data-row="qual"
                           style="flex:1; position:relative; border:1px solid #f0f0f0; border-radius:12px; background:#fafafa;">

                        <t t-if="is_draft">
                          <button type="button"
                                  class="btn_remove_row"
                                  title="Remove"
                                  style="position:absolute; top:10px; right:10px;
                                         width:30px; height:30px; border-radius:10px;
                                         border:1px solid #dc3545; background:#dc3545;
                                         display:flex; align-items:center; justify-content:center;
                                         cursor:pointer; text: white">
                            <i class="fa fa-trash" style="color:#ffffff; font-size:18px;"></i>
                          </button>
                        </t>

                        <div class="hrmis-form__grid pt-3 pb-2" style="grid-template-columns: repeat(12, minmax(0, 1fr)); gap: 10px;">
                          <div class="hrmis-field" style="grid-column: span 3;">
                            <label>Degree<span class="req">*</span></label>
                            <select class="hrmis-input" name="qualification_degree[]" required="required">
                              <option value="" disabled="disabled" selected="selected" hidden="hidden">Select Degree</option>
                              <option value="ms">MS</option>
                              <option value="md">MD</option>
                              <option value="fcps_1">FCPS-I</option>
                              <option value="fcps_2">FCPS-II</option>
                              <option value="mcps">MCPS</option>
                              <option value="diploma">Diploma</option>
                            </select>
                          </div>

                          <div class="hrmis-field" style="grid-column: span 4;">
                            <label>Specialization</label>
                            <input class="hrmis-input" type="text" name="qualification_specialization[]" placeholder="e.g. Cardiology"/>
                          </div>

                          <div class="hrmis-field" style="grid-column: span 2;">
                            <label>Start (MM-YYYY)<span class="req">*</span></label>
                            <input class="hrmis-input" type="month" name="qualification_start[]" required="required"/>
                          </div>

                          <div class="hrmis-field" style="grid-column: span 1; display:flex; align-items:center; gap:8px; padding-top:28px;">
                            <input type="checkbox" class="form-check-input js-qual-completed" name="qualification_completed[]"/>
                            <label style="margin:0;">Completed</label>
                          </div>

                          <div class="hrmis-field js-qual-end-wrap" style="grid-column: span 2; display:none;">
                            <label>End (MM-YYYY)<span class="req">*</span></label>
                            <input class="hrmis-input js-qual-end" type="month" name="qualification_end[]"/>
                          </div>

                        </div>
                      </div>

                    </div>
                  </template>

                  </div>
                </div>
              </div>

<!-- ===================== Posting History ===================== -->
<div class="hrmis-section" style="grid-column: 1 / -1;">
  <div class="hrmis-panel">

    <div class="hrmis-panel__title hrmis-panel__header" style="margin-bottom:10px;">
      Posting History
    </div>

    <div class="px-3 pt-1 pb-3">

      <fieldset t-att-disabled="'disabled' if not is_draft else None" style="border:0; padding:0; margin:0;">
        <div class="hrmis-leave-row-wrap d-flex align-items-stretch" style="gap:10px; border: 2px solid black; margin-bottom: 12px;">
          <div class="hrmis-card p-3" style="flex:1; border:1px solid #f0f0f0; border-radius:12px; background:#fafafa;">
            <div style="font-weight:600; font-size:14px; margin-bottom:8px;">Current Posting</div>

            <div class="hrmis-form__grid pt-3 pb-2" style="grid-template-columns: repeat(12, minmax(0, 1fr)); gap: 10px;">

              <div class="hrmis-field" style="grid-column: span 3;">
                <label>District<span class="req">*</span></label>
                <select class="hrmis-input js-current-district" name="district_id" t-att-required="'required' if is_draft else None"
                        t-att-disabled="'disabled' if not is_draft else None">
                  <option value="" disabled="disabled" hidden="hidden"
                          t-att-selected="(not is_draft) or (is_draft and not (req.district_id or current_employee.district_id))">
                    Select District
                  </option>
                  <t t-if="is_draft">
                    <t t-foreach="districts" t-as="d">
                      <option t-att-value="d.id"
                              t-att-selected="(req.district_id and req.district_id.id == d.id) or (current_employee.district_id and current_employee.district_id.id == d.id)">
                        <t t-esc="d.name"/>
                      </option>
                    </t>
                  </t>
                </select>
              </div>

              <div class="hrmis-field" style="grid-column: span 3;">
                <label>Facility</label>
                <select class="hrmis-input js-current-facility" name="facility_id"
                        t-att-disabled="'disabled' if not is_draft else None">
                  <option value="" selected="selected" t-att-selected="not is_draft">Select Facility</option>
                  <t t-if="is_draft">
                    <t t-foreach="facilities" t-as="f">
                      <option t-att-value="f.id"
                              t-att-data-district-id="f.district_id.id if f.district_id else ''"
                              t-att-selected="(req.facility_id and req.facility_id.id == f.id) or (current_employee.facility_id and current_employee.facility_id.id == f.id)">
                        <t t-esc="f.name"/>
                      </option>
                    </t>
                  </t>
                </select>
              </div>

              <div class="hrmis-field" style="grid-column: span 3;">
                <label>Designation<span class="req">*</span></label>
                <select class="hrmis-input" name="hrmis_designation" t-att-required="'required' if is_draft else None"
                        t-att-disabled="'disabled' if not is_draft else None">
                  <option value="" disabled="disabled" hidden="hidden"
                          t-att-selected="(not is_draft) or (is_draft and not (req.hrmis_designation or current_employee.hrmis_designation))">
                    Select Designation
                  </option>
                  <t t-if="is_draft">
                    <t t-foreach="designations_unique" t-as="des">
                      <option t-att-value="des.id"
                              t-att-selected="(req.hrmis_designation and req.hrmis_designation.id == des.id) or (current_employee.hrmis_designation and current_employee.hrmis_designation.id == des.id)">
                        <t t-esc="des.name"/>
                      </option>
                    </t>
                  </t>
                </select>
              </div>

              <div class="hrmis-field" style="grid-column: span 1;">
                <label>BPS<span class="req">*</span></label>
                <input class="hrmis-input" type="number" min="1" max="22" name="hrmis_bps"
                       t-att-required="'required' if is_draft else None"
                       t-att-value="(req.hrmis_bps or current_employee.hrmis_bps or '') if is_draft else ''"
                       t-att-readonly="'readonly' if not is_draft else None"/>
              </div>

              <div class="hrmis-field" style="grid-column: span 2;">
                <label>Start (MM-YYYY)<span class="req">*</span></label>
                <t t-set="cps_val" t-value="''"/>
                <t t-if="is_draft and req and ('current_posting_start' in req._fields)">
                  <t t-set="cps_val" t-value="req.current_posting_start or ''"/>
                </t>
                <input class="hrmis-input js-current-post-start"
                       type="month"
                       name="current_posting_start"
                       t-att-required="'required' if is_draft else None"
                       t-att-value="cps_val"
                       t-att-readonly="'readonly' if not is_draft else None"/>
              </div>

            </div>
          </div>
        </div>
      </fieldset>

      <!-- Previous Posting History (hidden/shown by JS) -->
      <div class="js-prev-posting-wrap" style="display:none;">

        <div class="d-flex align-items-center justify-content-between" style="gap:12px; margin-bottom:15px;">
          <div style="color:#dc3545; font-weight:400; margin:0; padding:0; font-size: 16px">
            Note: Kindly add your Previous Posting History carefully!
          </div>

          <t t-if="is_draft">
            <button type="button"
                    class="hrmis-btn hrmis-btn--primary"
                    id="btn_add_prev_post_row">
              Add
            </button>
          </t>
        </div>

        <fieldset t-att-disabled="'disabled' if not is_draft else None" style="border:0; padding:0; margin:0;">
          <div id="prev_post_rows" class="d-flex flex-column gap-2"></div>
        </fieldset>

        <template id="tpl_prev_post_row">
          <div class="hrmis-leave-row-wrap d-flex align-items-stretch" style="gap:10px; border: 2px solid black">
            <div class="hrmis-repeat-row hrmis-card p-3"
                 data-row="prev_post"
                 style="flex:1; position:relative; border:1px solid #f0f0f0; border-radius:12px; background:#fafafa;">

              <t t-if="is_draft">
                <button type="button"
                        class="btn_remove_row"
                        title="Remove"
                        style="position:absolute; top:10px; right:10px;
                               width:30px; height:30px; border-radius:10px;
                               border:1px solid #dc3545; background:#dc3545;
                               display:flex; align-items:center; justify-content:center;
                               cursor:pointer; text: white">
                  <i class="fa fa-trash" style="color:#ffffff; font-size:18px;"></i>
                </button>
              </t>

              <div class="hrmis-form__grid pt-3 pb-2" style="grid-template-columns: repeat(12, minmax(0, 1fr)); gap: 10px;">

                <div class="hrmis-field" style="grid-column: span 3;">
                  <label>District<span class="req">*</span></label>
                  <select class="hrmis-input js-post-district" name="posting_district_id[]" required="required">
                    <option value="" disabled="disabled" selected="selected" hidden="hidden">Select District</option>
                    <t t-foreach="districts" t-as="d">
                      <option t-att-value="d.id"><t t-esc="d.name"/></option>
                    </t>
                  </select>
                </div>

                <div class="hrmis-field" style="grid-column: span 3;">
                  <label>Facility</label>
                  <select class="hrmis-input js-post-facility" name="posting_facility_id[]">
                    <option value="" selected="selected">Select Facility</option>
                    <t t-foreach="facilities" t-as="f">
                      <option t-att-value="f.id" t-att-data-district-id="f.district_id.id if f.district_id else ''">
                        <t t-esc="f.name"/>
                      </option>
                    </t>
                  </select>
                </div>

                <div class="hrmis-field" style="grid-column: span 3;">
                  <label>Designation<span class="req">*</span></label>
                  <select class="hrmis-input" name="posting_designation_id[]" required="required">
                    <option value="" disabled="disabled" selected="selected" hidden="hidden">Select Designation</option>
                    <t t-foreach="designations_unique" t-as="des">
                      <option t-att-value="des.id"><t t-esc="des.name"/></option>
                    </t>
                  </select>
                </div>

                <div class="hrmis-field" style="grid-column: span 1;">
                  <label>BPS<span class="req">*</span></label>
                  <input class="hrmis-input" type="number" min="1" max="22" name="posting_bps[]" required="required"/>
                </div>

                <div class="hrmis-field" style="grid-column: span 1;">
                  <label>Start<span class="req">*</span></label>
                  <input class="hrmis-input js-post-start" type="month" name="posting_start[]" required="required"/>
                </div>

                <div class="hrmis-field" style="grid-column: span 1;">
                  <label>End<span class="req">*</span></label>
                  <input class="hrmis-input js-post-end" type="month" name="posting_end[]" required="required"/>
                </div>

              </div>
            </div>
          </div>
        </template>

      </div><!-- /.js-prev-posting-wrap -->

    </div>
  </div>
</div>

<!-- ===================== Promotion History ===================== -->
<div class="hrmis-section" style="grid-column: 1 / -1;">
  <div class="hrmis-panel">

    <div class="hrmis-panel__title hrmis-panel__header" style="margin-bottom:10px;">
      Promotion History
    </div>

    <div class="px-3 pt-1 pb-3">

      <div class="d-flex align-items-center justify-content-between" style="gap:12px; margin-bottom:15px;">
        <div style="color:#dc3545; font-weight:400; margin:0; padding:0; font-size: 16px">
          Note: Kindly add your Promotion History carefully!
        </div>

        <t t-if="is_draft">
          <button type="button"
                  class="hrmis-btn hrmis-btn--primary"
                  id="btn_add_promo_row">
            Add
          </button>
        </t>
      </div>

      <fieldset t-att-disabled="'disabled' if not is_draft else None" style="border:0; padding:0; margin:0;">
        <div id="promo_rows" class="d-flex flex-column gap-2"></div>
      </fieldset>

      <template id="tpl_promo_row">
        <div class="hrmis-leave-row-wrap d-flex align-items-stretch" style="gap:10px; border: 2px solid black">

          <div class="hrmis-repeat-row hrmis-card p-3"
               data-row="promo"
               style="flex:1; position:relative; border:1px solid #f0f0f0; border-radius:12px; background:#fafafa;">

            <t t-if="is_draft">
              <button type="button"
                      class="btn_remove_row"
                      title="Remove"
                      style="position:absolute; top:10px; right:10px;
                             width:30px; height:30px; border-radius:10px;
                             border:1px solid #dc3545; background:#dc3545;
                             display:flex; align-items:center; justify-content:center;
                             cursor:pointer; text: white">
                <i class="fa fa-trash" style="color:#ffffff; font-size:18px;"></i>
              </button>
            </t>

            <div class="hrmis-form__grid pt-3 pb-2" style="grid-template-columns: repeat(12, minmax(0, 1fr)); gap: 10px;">

              <div class="hrmis-field" style="grid-column: span 4;">
                <label>BPS From<span class="req">*</span></label>
                <input class="hrmis-input" type="number" min="1" max="22" name="promotion_bps_from[]" required="required"/>
              </div>

              <div class="hrmis-field" style="grid-column: span 4;">
                <label>BPS To<span class="req">*</span></label>
                <input class="hrmis-input" type="number" min="1" max="22" name="promotion_bps_to[]" required="required"/>
              </div>

              <div class="hrmis-field" style="grid-column: span 4;">
                <label>Promotion Date (MM-YYYY)<span class="req">*</span></label>
                <input class="hrmis-input" type="month" name="promotion_date[]" required="required"/>
              </div>

            </div>
          </div>

        </div>
      </template>

    </div>
  </div>
</div>

 <!-- ===================== Leave History (FIXED TAGS) ===================== -->
              <div class="hrmis-section" style="grid-column: 1 / -1;">

                <!-- FIXED: use a single wrapper, no extra/mismatched closing divs -->
                <div class="hrmis-panel" >

                  <div class=" hrmis-panel__title hrmis-panel__header" style="margin-bottom:10px;">
                    Leave History
                  </div>

                  <div class="px-3 pt-1 pb-3">

                    <div class="d-flex align-items-center justify-content-between" style="gap:12px; margin-bottom:15px;">
                      <div style="color:#dc3545; font-weight:400; margin:0; padding:0; font-size: 16px">
                        Note: Kindly add your Leave History carefully!
                      </div>

                      <t t-if="is_draft">
                        <button type="button"
                                class="hrmis-btn hrmis-btn--primary"
                                id="btn_add_leave_row">
                          Add
                        </button>
                      </t>
                    </div>

                    <fieldset t-att-disabled="'disabled' if not is_draft else None" style="border:0; padding:0; margin:0;">
                      <div id="leave_rows" class="d-flex flex-column gap-2" ></div>
                    </fieldset>

                    <template id="tpl_leave_row">
                      <div class="hrmis-leave-row-wrap d-flex align-items-stretch" style="gap:10px; border: 2px solid black">

                        <div class="hrmis-repeat-row hrmis-card p-3"
                             data-row="leave"
                             style="flex:1; position:relative; border:1px solid #f0f0f0; border-radius:12px; background:#fafafa;">

                          <t t-if="is_draft">
                            <button type="button"
                                    class="btn_remove_row"
                                    title="Remove"
                                    style="position:absolute; top:10px; right:10px;
                                           width:30px; height:30px; border-radius:10px;
                                           border:1px solid #dc3545; background:#dc3545;
                                           display:flex; align-items:center; justify-content:center;
                                           cursor:pointer; text: white">
                              <i class="fa fa-trash" style="color:#ffffff; font-size:18px;"></i>
                            </button>
                          </t>

                          <div class="hrmis-form__grid pt-3 pb-2" style="grid-template-columns: repeat(12, minmax(0, 1fr)); gap: 10px;">

                            <div class="hrmis-field" style="grid-column: span 4;">
                              <label>Leave Type<span class="req">*</span></label>
                              <select class="hrmis-input" name="leave_type_id[]" required="required">
                                <option value="" disabled="disabled" selected="selected" hidden="hidden">Select Leave Type</option>
                                <t t-set="emp_gender"
                                   t-value="((req.gender or current_employee.gender or '') or '').lower()"/>
                                <t t-foreach="env['hr.leave.type'].sudo().search([], order='name')" t-as="lt">
                                  <t t-set="lt_name" t-value="(lt.name or '').lower()"/>
                                  <t t-if="
                                      ('casual' not in lt_name)
                                      and ('compensatory' not in lt_name)
                                      and ('paid time off' not in lt_name)
                                      and ('sick time off' not in lt_name)
                                      and ('lpr' not in lt_name)
                                      and (lt_name.strip() != 'unpaid')
                                      and (emp_gender != 'male' or ('maternity' not in lt_name))
                                  ">
                                    <option t-att-value="lt.id"><t t-esc="lt.name"/></option>
                                  </t>
                                </t>
                              </select>
                            </div>

                            <div class="hrmis-field" style="grid-column: span 4;">
                              <label>Start Date<span class="req">*</span></label>
                              <input class="hrmis-input" type="date" name="leave_start[]" required="required" t-att-max="max_past_str"/>
                            </div>

                            <div class="hrmis-field" style="grid-column: span 4;">
                              <label>End Date<span class="req">*</span></label>
                              <input class="hrmis-input" type="date" name="leave_end[]" required="required" t-att-max="max_today_str"/>
                            </div>

                          </div>
                        </div>

                      </div>
                    </template>

                    <div class="hrmis-field" style="margin-top:15px;">
                      <label>Total Leaves Taken Since Joining (Days)<span class="req">*</span></label>
                      <input class="hrmis-input js-hrmis-leaves-taken"
                             type="number"
                             step="0.5"
                             min="0"
                             max="365"
                             name="hrmis_leaves_taken"
                             t-att-required="'required' if is_draft else None"
                             readonly="readonly"
                             style="background:#f3f4f6; color:#6c757d; opacity:0.75; filter: blur(0.15px); width:50%;"
                             t-att-value="(req.hrmis_leaves_taken or current_employee.hrmis_leaves_taken or 0) if is_draft else ''"/>
                      <div class="hrmis-help" style="color:#6c757d; margin-top:5px;">Auto-calculated from Leave History.</div>
                    </div>

                  </div><!-- /.px-2 -->

                </div><!-- /.hrmis-panel__body -->
              </div><!-- /.hrmis-section -->

            </div><!-- /.hrmis-form__grid -->


            <t t-if="req.state == 'draft'">
              <div class="hrmis-form__actions">
                <button class="hrmis-btn hrmis-btn--primary hrmis-btn--lg"
                        type="button"
                        id="btn_open_confirm_modal">
                  Submit Request
                </button>
              </div>
            </t>

          </form>

        </div><!-- /.hrmis-panel__body -->
      </div><!-- /.hrmis-panel -->

      <t t-if="req.state == 'draft'">
        <!-- Confirmation Modal (ONLY ONCE) -->
        <div class="modal fade" id="confirmSubmitModal" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-lg modal-dialog-scrollable" style="display:flex; align-items:center">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title" style="font-weight:800;">Confirm Profile Update Request</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <div class="modal-body">
                <p class="mb-3">Please review the information below before submitting.</p>
                <div class="table-responsive">
                  <table class="table table-sm align-middle">
                    <tbody id="confirm_table_body"></tbody>
                  </table>
                </div>
              </div>

              <div class="modal-footer">
                <button type="button" class="hrmis-btn hrmis-btn--primary hrmis-btn--lg" id="btn_confirm_submit">
                  Confirm &amp; Submit
                </button>
              </div>
            </div>
          </div>
        </div>
      </t>

    </t>
  </template>
</odoo>
