<odoo>
    <template id="transfer_letter_add_download_notification_form_manage_history"
              inherit_id="custom_section_officers.hrmis_manage_requests">

        <xpath expr="//div[@class='hrmis-btn-placeholder']" position="replace">

            <div class="hrmis-transfer-action">
                <t t-if="tr.state == 'approved' and tr.transfer_notification_id">
                    <a t-att-href="'/transfer_letter/pdf/%s' % tr.transfer_notification_id.id"
                       class="hrmis-btn hrmis-btn--outline"
                       target="_blank"
                       t-attf-style="
                            background: #{ not tr.transfer_notification_id.is_downloaded and '#064526' or 'white' };
                            color: #{ not tr.transfer_notification_id.is_downloaded and 'white' or '#333' };
                            border:1px solid #064526;
                       ">

                        <t t-esc="not tr.transfer_notification_id.is_downloaded and 'Download' or 'Downloaded'"/>

                    </a>
                </t>

                <t t-else="">
    <span style="
        display: inline-block;
        font-size: 12px;
        color: #888;
        padding: 6px 12px;
        border: 1px dashed #ccc;
        border-radius: 6px;
        background: #f5f5f5;
        min-width: 100px;
        text-align: center;
        white-space: normal;
        overflow-wrap: break-word;">
        No notification available
    </span>
</t>

            </div>

        </xpath>

    </template>
</odoo>
